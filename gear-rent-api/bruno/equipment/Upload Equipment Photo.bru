meta {
  name: Upload Equipment Photo
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/equipment/{{equipmentId}}/photo
  body: file
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  photo: @file(/home/atrokhymchuk/tmpfiles/Lenna.png)
}

body:file {
  file: @file(/home/atrokhymchuk/tmpfiles/Lenna.png) @contentType(image/png)
}
