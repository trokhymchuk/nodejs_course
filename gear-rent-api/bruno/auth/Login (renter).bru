meta {
  name: Login (renter)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "ivan@renter.com",
    "password": "password"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data?.accessToken) {
    bru.setVar("accessToken", res.body.data.accessToken);
  }
}
