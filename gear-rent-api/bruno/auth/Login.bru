meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "ivan@rent.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data?.accessToken) {
    bru.setEnvVar("accessToken", res.body.data.accessToken);
  }
}
